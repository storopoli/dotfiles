  // Flatpak
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.profiles.linux": {
    "bash": {
      "path": "/usr/bin/flatpak-spawn",
      "args": [
        "--host",
        "--env=TERM=xterm-256color",
        "script",
        "--quiet",
        "/dev/null"
      ]
    },
    "zsh": {
      "path": "/usr/bin/flatpak-spawn",
      "args": [
        "--host",
        "--env=TERM=xterm-256color",
        "--env=SHELL=zsh",
        "script",
        "--quiet",
        "/dev/null"
      ]
    }
  },
  // Git settings
  "git.autofetch": true,
  "git.autorefresh": true,
  "git.confirmSync": false,
  "git.enableCommitSigning": true,
  "github.gitProtocol": "ssh",
  // LiveShare
  "liveshare.presence": true,
  // Julia
  "julia.execution.codeInREPL": true,
  "julia.enableCrashReporter": false,
  "julia.enableTelemetry": false,
  "julia.executablePath": "/var/home/storopoli/.juliaup/bin/julia",
  "julia.useRevise": true,
  "julia.symbolCacheDownload": true,
  "julia.NumThreads": "auto",
  "julia.runtimeCompletions": true,
  // "julia.persistentSession.enabled": true,
  "terminal.integrated.commandsToSkipShell": [
    "language-julia.interrupt"
  ],
  // Python
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.formatting.provider": "black",
  // LaTeX
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.recipes": [
    {
      "name": "tectonic",
      "tools": [
        "tectonic"
      ]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "tectonic",
      "command": "tectonic",
      "args": [
        "-X",
        "build"
        // "%DOC%.tex"
      ],
      "env": {}
    }
  ],
  "[latex]": {
    "editor.formatOnPaste": false,
    "editor.formatOnSave": false,
    "editor.suggestSelection": "recentlyUsedByPrefix"
  },
  "[bibtex]": {
    "editor.formatOnPaste": false,
    "editor.formatOnSave": false
  },
  // Flatpak toolbox hack
  "dev.containers.dockerPath": "/var/home/storopoli/.local/bin/podman-host"
}